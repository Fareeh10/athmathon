    <script>
        function toggleModal(show) {
            const modal = document.getElementById('askModal');
            if(show) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        function switchTab(tab) {
            const dis = document.getElementById('tab-dis');
            const art = document.getElementById('tab-art');
            if(tab === 'discussions') {
                dis.className = "px-4 py-2 border-b-2 border-brand-blue brand-blue transition";
                art.className = "px-4 py-2 text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition";
            } else {
                art.className = "px-4 py-2 border-b-2 border-brand-blue brand-blue transition";
                dis.className = "px-4 py-2 text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition";
            }
        }

        // Close modal on click outside
        window.onclick = function(event) {
            const modal = document.getElementById('askModal');
            if (event.target == modal) {
                toggleModal(false);
            }
        }
    </script>
