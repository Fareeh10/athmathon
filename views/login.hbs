<section class="w-full flex justify-center items-center h-[calc(100vh-85px)]">
    <div class="bg-white shadow-lg rounded-2xl p-8 w-full max-w-md" style="border: 1px solid rgba(128, 128, 128, 0.15);">
        
        <!-- Logo / Title -->
        <h2 class="text-2xl font-bold text-center mb-6">
            Welcome Back
        {{!--  <i class="fa-solid fa-hand rot"></i> --}}
        </h2>

        <p class="text-gray-500 text-center mb-6">
        Continue building your skills
        </p>

        <!-- Form -->
        <form action="/login" method="POST" class="space-y-4">

        <div>
            <label class="block text-sm font-medium mb-1">Username</label>
            <input type="text" name="username" required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Enter your username">
        </div>

        <div>
            <label class="block text-sm font-medium mb-1">Password</label>
            <input type="password" name="password" required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Enter your password">
        </div>

        <button type="submit"
            class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition">
            Login
        </button>

        </form>

        <!-- Divider -->
        <div class="text-center my-4 text-gray-400">or</div>

        <!-- Demo Login (Hackathon Trick) -->
        <a href="/home"
        class="block text-center bg-gray-200 py-2 rounded-lg hover:bg-gray-300">
        Continue as Guest
        </a>

        <!-- Signup -->
        <p class="text-center text-sm mt-4">
        Don’t have an account?
        <a href="#" class="text-blue-600 hover:underline">Sign up</a>
        </p>

    </div>
</section>
